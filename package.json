{
  "name": "ghost-city-rlt",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "electron .",
    "dist": "next build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ghostcityrlt",
    "productName": "Ghost City RLT",
    "copyright": "Copyright © 2026",
    "npmRebuild": true,
    "files": [
      "electron/**/*",
      ".next/**/*",
      "app/generated/**/*",
      "lib/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.*",
      "!.next/cache/**/*",
      "!**/*.bat",
      "!scripts/**/*",
      "!*.db",
      "!.env*",
      "!README.md",
      "!{.git,.gitignore}",
      "!node_modules/@prisma/engines/**/*",
      "!node_modules/prisma/build/**/*",
      "!node_modules/typescript/**/*",
      "!node_modules/eslint*/**/*",
      "!node_modules/@eslint*/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/__tests__/**/*",
      "!node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "prisma/migrations",
        "to": "migrations"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ghost City RLT"
    },
    "portable": {
      "artifactName": "${productName} Portable ${version}.exe"
    }
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.4.0",
    "madden-franchise": "^4.3.1",
    "next": "16.2.10",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
